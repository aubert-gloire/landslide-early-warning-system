# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=landslide_ews

# --- Telerivet (SMS provider — routes through an Android SIM route) ---
# Africa's Talking was evaluated and removed; see docs/africastalking-investigation.md
TELERIVET_API_KEY=your_telerivet_api_key
TELERIVET_PROJECT_ID=your_telerivet_project_id
TELERIVET_ROUTE_ID=your_telerivet_android_sim_route_id  # leave blank to use Telerivet's default route
# Delivery-status webhook (POST /api/sms/telerivet-status) -- lets delivery_status
# become a real "delivered" instead of staying at "sent" (queue-accepted) forever.
# Leave either blank to disable; Telerivet will just never be asked for a status update.
TELERIVET_STATUS_SECRET=a_random_string_you_choose
PUBLIC_API_BASE_URL=https://your-backend.onrender.com

# --- OpenTopography (Copernicus DEM) ---
OPENTOPO_API_KEY=your_opentopography_api_key

# --- Gemini (help chat — optional; falls back to rule-based answers if unset) ---
GEMINI_API_KEY=your_gemini_api_key

# --- Google Earth Engine (Sentinel-2 NDVI) ---
# Service account JSON path OR set GOOGLE_APPLICATION_CREDENTIALS
GEE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/gee_key.json

# --- App ---
APP_ENV=development          # development | production
SECRET_KEY=change_me_in_production
ALERT_PROBABILITY_THRESHOLD=0.80

# --- Frontend (Vite reads VITE_ prefix) ---
VITE_API_BASE_URL=http://localhost:8000
