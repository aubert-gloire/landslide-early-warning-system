# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=landslide_ews

# --- Africa's Talking ---
AT_USERNAME=sandbox          # change to your live username when go live
AT_API_KEY=your_api_key_here
AT_SENDER_ID=LSEWS           # shortcode registered with AT (optional for sandbox)

# --- OpenTopography (Copernicus DEM) ---
OPENTOPO_API_KEY=your_opentopography_api_key

# --- Google Earth Engine (Sentinel-2 NDVI) ---
# Service account JSON path OR set GOOGLE_APPLICATION_CREDENTIALS
GEE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/gee_key.json

# --- App ---
APP_ENV=development          # development | production
SECRET_KEY=change_me_in_production
ALERT_PROBABILITY_THRESHOLD=0.80

# --- Frontend (Vite reads VITE_ prefix) ---
VITE_API_BASE_URL=http://localhost:8000
