# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# Env
.env
.env.local
.env.*.local

# Secrets — NEVER commit GEE service account key or any credentials
secrets/

# Data (large rasters & raw downloads — not tracked in git)
data/raw/
data/processed/*.tif
data/processed/*.tiff
data/processed/*.nc
data/processed/*.parquet
ml/artifacts/*.pkl

# Keep placeholder files and the trained model (401KB — checked in for Render deploy)
!data/raw/.gitkeep
!data/processed/.gitkeep
!ml/artifacts/.gitkeep
!ml/artifacts/rf_model.joblib

# Static per-unit feature tables (~35KB total) — required by
# FeatureMatrixBuilder._load_static() at inference time. Without these,
# every prediction silently scores on null terrain/NDVI/soil/landuse and
# rainfall alone (found 2026-07-23: production had been doing exactly this
# since deploy, because this blanket *.parquet rule swallowed them too).
!data/processed/terrain_per_unit.parquet
!data/processed/ndvi_2023.parquet
!data/processed/soil_per_unit.parquet
!data/processed/landuse_per_unit.parquet

# Node
node_modules/
frontend/dist/
frontend/.vite/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Logs
*.log
logs/
